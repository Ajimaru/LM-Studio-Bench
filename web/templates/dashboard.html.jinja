                    <div class="chart-stats">
                        <div class="chart-stat">
                            <div class="chart-stat-label">Min</div>
                            <div class="chart-stat-value" id="cpu-min">--%</div>
                        </div>
                        <div class="chart-stat">
                            <div class="chart-stat-label">Ø</div>
                            <div class="chart-stat-value" id="cpu-avg">--%</div>
