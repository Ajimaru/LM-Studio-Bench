    <title>LM Studio Benchmark Dashboard</title>
    
    <!-- Favicon - Bar Chart Design -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' fill='%233b82f6' rx='16'/><rect x='15' y='60' width='15' height='35' fill='%2310b981' rx='2'/><rect x='40' y='35' width='15' height='60' fill='%2310b981' rx='2'/><rect x='65' y='20' width='15' height='75' fill='%2310b981' rx='2'/></svg>">
    
    <!-- Plotly.js für Hardware-Monitoring Charts -->
