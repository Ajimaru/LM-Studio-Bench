                            <tr style="background: rgba(0,0,0,0.1); border-bottom: 2px solid rgba(0,0,0,0.2);">
                                <th style="padding: 0.75rem; text-align: left; font-weight: 600;">Modell</th>
                                <th style="padding: 0.75rem; text-align: left; font-weight: 600;">Quantisierung</th>
                                <th style="padding: 0.75rem; text-align: right; font-weight: 600;">Tokens/s</th>
                                <th style="padding: 0.75rem; text-align: right; font-weight: 600;">VRAM (MB)</th>
                            </tr>
                        </thead>
                        <tbody id="home-top-models">
                            <tr><td colspan="4" style="text-align: center; padding: 2rem; opacity: 0.6;">Lade Daten...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Recent Runs -->
            <div class="section">
                <h3>🕐 Letzte Benchmark-Runs</h3>
                <div class="card">
                    <table style="width: 100%; border-collapse: collapse;" id="home-recent-runs-table">
                        <thead>
                            <tr style="background: rgba(0,0,0,0.1); border-bottom: 2px solid rgba(0,0,0,0.2);">
