        <!-- RESULTS VIEW -->
        <div id="view-results" class="view-container hidden">
            <div class="section">
                <h3>📊 Benchmark-Ergebnisse</h3>
                <div class="card" style="padding: 1rem;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                        <div>
                            <span id="cache-stats-text-results" style="font-size: 0.9rem; opacity: 0.8;">Lade Cache-Statistiken...</span>
                        </div>
                        <div style="display: flex; gap: 0.5rem;">
                            <button class="btn-primary" onclick="loadResults()" style="padding: 0.4rem 0.8rem; font-size: 0.85rem;" title="Shortcut: R">🔄 Aktualisieren <span style="opacity: 0.7;">(R)</span></button>
                            <button class="btn-danger" onclick="clearCache()" style="padding: 0.4rem 0.8rem; font-size: 0.85rem;">🗑️ Cache Löschen</button>
                        </div>
                    </div>
                    <div style="overflow-x: auto;">
                        <table id="results-table" style="width: 100%; border-collapse: collapse;">
                            <thead>
                                <tr style="background: rgba(0,0,0,0.1); border-bottom: 2px solid rgba(0,0,0,0.2);">
                                    <th onclick="sortTable(0)" style="cursor: pointer; padding: 0.75rem; text-align: left; font-weight: 600;">Modell ⇅</th>
                                    <th onclick="sortTable(1)" style="cursor: pointer; padding: 0.75rem; text-align: left; font-weight: 600;">Quantisierung ⇅</th>
                                    <th onclick="sortTable(2)" style="cursor: pointer; padding: 0.75rem; text-align: right; font-weight: 600;">Tokens/s ⇅</th>
                                    <th onclick="sortTable(3)" style="cursor: pointer; padding: 0.75rem; text-align: right; font-weight: 600;">VRAM (MB) ⇅</th>
                                    <th onclick="sortTable(4)" style="cursor: pointer; padding: 0.75rem; text-align: right; font-weight: 600;">GPU-Offload ⇅</th>
                                    <th onclick="sortTable(5)" style="cursor: pointer; padding: 0.75rem; text-align: left; font-weight: 600;">GPU-Typ ⇅</th>
                                    <th style="padding: 0.75rem; text-align: center; font-weight: 600;">Aktionen</th>
                                </tr>
                            </thead>
                            <tbody id="results-tbody">
                                <tr>
                                    <td colspan="7" style="text-align: center; padding: 2rem; opacity: 0.6;">
                                        Keine Ergebnisse im Cache. Starte einen Benchmark!
