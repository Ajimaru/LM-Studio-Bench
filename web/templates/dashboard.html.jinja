            <select id="theme-selector" onchange="switchTheme(this.value)" style="padding: 0.5rem; border: 1px solid rgba(255,255,255,0.3); border-radius: 0.5rem; background: rgba(255,255,255,0.1); color: white; font-weight: 600; cursor: pointer;">
