        <!-- RESULTS VIEW -->
        <div id="view-results" class="view-container hidden" style="min-height: 500px;">
            <div class="section" style="min-height: 400px;">
                <h3>📊 Benchmark-Ergebnisse</h3>
                <div class="card" style="padding: 1rem; min-height: 300px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                        <div>
                            <span id="cache-stats-text-results" style="font-size: 0.9rem; opacity: 0.8;">Lade Cache-Statistiken...</span>
                        </div>
                        <div style="display: flex; gap: 0.5rem;">
                            <button class="btn-primary" onclick="loadResults()" style="padding: 0.4rem 0.8rem; font-size: 0.85rem;" title="Shortcut: R">🔄 Aktualisieren <span style="opacity: 0.7;">(R)</span></button>
                            <button class="btn-danger" onclick="clearCache()" style="padding: 0.4rem 0.8rem; font-size: 0.85rem;">🗑️ Cache Löschen</button>
                        </div>
                    </div>
                    <div style="overflow-x: auto;">
                        <table id="results-table" style="width: 100%; border-collapse: collapse;">
                            <thead>
                                <tr style="background: rgba(255,255,255,0.05); border-bottom: 2px solid rgba(255,255,255,0.12);">
                                    <th onclick="sortTable(0)" style="cursor: pointer; padding: 0.75rem; text-align: left; font-weight: 700;">Modell ⇅</th>
                                    <th onclick="sortTable(1)" style="cursor: pointer; padding: 0.75rem; text-align: left; font-weight: 700;">Quantisierung ⇅</th>
                                    <th onclick="sortTable(2)" style="cursor: pointer; padding: 0.75rem; text-align: right; font-weight: 700;">Tokens/s ⇅</th>
                                    <th onclick="sortTable(3)" style="cursor: pointer; padding: 0.75rem; text-align: right; font-weight: 700;">VRAM (MB) ⇅</th>
                                    <th onclick="sortTable(4)" style="cursor: pointer; padding: 0.75rem; text-align: right; font-weight: 700;">GPU-Offload ⇅</th>
                                    <th onclick="sortTable(5)" style="cursor: pointer; padding: 0.75rem; text-align: left; font-weight: 700;">GPU-Typ ⇅</th>
                                    <th style="padding: 0.75rem; text-align: center; font-weight: 700;">Aktionen</th>
                                </tr>
                            </thead>
                            <tbody id="results-tbody">
                                <tr>
                                    <td colspan="7" style="text-align: center; padding: 2rem; opacity: 0.6;">
                                        Keine Ergebnisse im Cache. Starte einen Benchmark!
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <!-- END RESULTS VIEW -->
    </div>
    <!-- END CONTAINER -->

    <!-- Back to Top Button -->
    <button class="back-to-top" title="Nach oben scrollen" onclick="scrollToTop()">⬆️</button>

    <!-- Toast Container -->
    <div class="toast-container" id="toast-container"></div>

    <script>
        // ===== Globale Variablen =====
        let websocket = null;
        let statusCheckInterval = null;
        let lmstudioHealthInterval = null;
        let uptimeInterval = null;
        let startTime = null;

        // ===== Theme Switching =====
        function switchTheme(themeName) {
            // Entferne alle Theme-Klassen
            const allThemes = [
                'dark-mode',
                'theme-ocean', 'theme-slate', 'theme-mint', 'theme-speed', 'theme-neon',
                'theme-solarized-dark', 'theme-solarized-light', 'theme-gruvbox', 'theme-dracula', 'theme-nord', 'theme-monokai',
                'theme-paper', 'theme-terminal-green', 'theme-oled', 'theme-forest', 'theme-sunset', 'theme-cyberpunk', 'theme-pastel', 'theme-sepia', 'theme-80s',
                'theme-90s', 'theme-hacker', 'theme-hardware', 'theme-contrast-dark', 'theme-contrast-light'
            ];
            allThemes.forEach(theme => document.body.classList.remove(theme));
            
            // Setze neues Theme
            if (themeName === 'dark') {
                document.body.classList.add('dark-mode');
            } else if (themeName !== 'light') {
                document.body.classList.add(themeName);
            }
            
            // Speichern in LocalStorage
            localStorage.setItem('theme', themeName);
        }

        function restoreTheme() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            const selector = document.getElementById('theme-selector');
            if (selector) selector.value = savedTheme;
            switchTheme(savedTheme);
        }

        // ===== Update Export Links =====
        async function updateExportLinks() {
            try {
                // Hole die neuesten Benchmark-Ergebnisse vom Server
                const response = await fetch('/api/latest-results');
                const data = await response.json();
                
                if (data.latest) {
                    // data.latest enthält nur den Dateinamen (z.B. "benchmark_results_20260105_195003.json")
                    const baseFileName = data.latest.replace(/\.\w+$/, '');
                    
                    // Aktualisiere die Links
                    document.getElementById('exportHTML').href = `/results/${baseFileName}.html`;
                    document.getElementById('exportPDF').href = `/results/${baseFileName}.pdf`;
                    document.getElementById('exportJSON').href = `/results/${baseFileName}.json`;
                    document.getElementById('exportCSV').href = `/results/${baseFileName}.csv`;
                } else {
                    // Fallback: Alle Links auf resultsverzeichnis
                    const links = ['exportHTML', 'exportPDF', 'exportJSON', 'exportCSV'];
                    links.forEach(id => {
                        document.getElementById(id).href = '/results/';
                    });
                }
            } catch (error) {
                console.error('Fehler beim Laden der Export-Links:', error);
                // Fallback: Alle Links auf results-verzeichnis
                const links = ['exportHTML', 'exportPDF', 'exportJSON', 'exportCSV'];
                links.forEach(id => {
                    document.getElementById(id).href = '/results/';
                });
            }
        }

        // Theme auf Laden einrichten
        // Results beim Laden initialisieren
        // WebSocket & Timers starten
        window.addEventListener('DOMContentLoaded', () => {
            // Stelle Theme aus localStorage wieder her
            restoreTheme();
            
            // Lade Dashboard-Stats wenn Home-View aktiv
            loadDashboardStats();
            
            // Lade Results
            loadResults();
            
            // Aktualisiere Export-Links
            updateExportLinks();
            
            // Starte WebSocket & Timers
            setupWebSocket();
            updateStatus();
            updateUptime();
            
            statusCheckInterval = setInterval(updateStatus, 2000);
            uptimeInterval = setInterval(updateUptime, 1000);
            lmstudioHealthInterval = setInterval(checkLMStudioHealth, 5000);  // LM Studio Health alle 5s

            // Stelle sicher, dass eine View sichtbar ist (Home als Default)
            showView('home');
        });

        // ===== View Switching =====
        function showView(viewName) {
            // Hide all views
            document.querySelectorAll('.view-container').forEach(view => {
                view.classList.add('hidden');
            });
            
            // Show selected view
            const selectedView = document.getElementById(`view-${viewName}`);
            if (selectedView) {
                selectedView.classList.remove('hidden');
            }
            
            // Update navigation buttons
            document.querySelectorAll('.nav-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            const activeBtn = document.querySelector(`.nav-btn[data-view="${viewName}"]`);
            if (activeBtn) {
                activeBtn.classList.add('active');
            }
            
            // Load data for specific views
            if (viewName === 'home') {
                loadDashboardStats();
            } else if (viewName === 'results') {
                loadResults();
                updateCacheStats();
            } else if (viewName === 'benchmark') {
                updateCacheStats();
            }
        }

        // ===== Toast Notifications =====
        function showToast(message, type = 'info', title = null, duration = 4000) {
            const toastContainer = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = `toast toast-${type}`;
            
            const icons = {
                success: '✅',
                error: '❌',
                warning: '⚠️',
                info: 'ℹ️'
            };
            
            const titles = {
                success: title || 'Erfolg',
                error: title || 'Fehler',
                warning: title || 'Warnung',
                info: title || 'Info'
            };
            
            toast.innerHTML = `
                <div class="toast-icon">${icons[type]}</div>
                <div class="toast-content">
                    <div class="toast-title">${titles[type]}</div>
                    <div class="toast-message">${message}</div>
                </div>
                <button class="toast-close" onclick="closeToast(this)">×</button>
            `;
            
            toastContainer.appendChild(toast);
            
            // Auto-dismiss
            if (duration > 0) {
                setTimeout(() => {
                    closeToast(toast.querySelector('.toast-close'));
                }, duration);
            }
        }

        function closeToast(button) {
            const toast = button.closest('.toast');
            toast.classList.add('removing');
            setTimeout(() => {
                toast.remove();
            }, 300);
        }

        // ===== Keyboard Shortcuts =====
        document.addEventListener('keydown', (e) => {
            // Ignore wenn Input-Feld aktiv
            if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') {
                return;
            }
            
            switch(e.key.toLowerCase()) {
                case 's':
                    e.preventDefault();
                    showView('benchmark');
                    if (!document.getElementById('startModal').classList.contains('hidden')) {
                        startBenchmark();
                    } else {
                        toggleStartModal();
                    }
                    break;
                case 'q':
                    e.preventDefault();
                    if (confirm('Benchmark wirklich stoppen?')) {
                        stopBenchmark();
                    }
                    break;
                case 'r':
                    e.preventDefault();
                    if (document.getElementById('view-results').classList.contains('hidden') === false) {
                        loadResults();
                        showToast('Ergebnisse aktualisiert', 'success');
                    }
                    break;
                case 'escape':
                    e.preventDefault();
                    const modal = document.getElementById('startModal');
                    if (!modal.classList.contains('hidden')) {
                        toggleStartModal();
                    }
                    break;
                case 'h':
                    e.preventDefault();
                    showView('home');
                    break;
                case 'b':
                    e.preventDefault();
                    showView('benchmark');
                    break;
            }
        });

        // ===== LM Studio Health Check (Live Update) =====
        function updateLMStudioHealth(lmstudio) {
            const el = document.getElementById('home-lmstudio-version');
            if (!el) return;
            
            if (lmstudio && lmstudio.ok) {
                const version = lmstudio.version ? `Online (v${lmstudio.version})` : 'Online';
                el.textContent = version;
                el.style.color = 'var(--success)';
            } else {
                el.textContent = 'Offline';
                el.style.color = '#e74c3c';
            }
        }
        
        async function checkLMStudioHealth() {
            try {
                const response = await fetch('/api/lmstudio/health');
                const data = await response.json();
                updateLMStudioHealth(data);
            } catch (error) {
                updateLMStudioHealth({ ok: false });
            }
        }

        // ===== Dashboard Stats Loading =====
        async function loadDashboardStats() {
            try {
                const response = await fetch('/api/dashboard/stats');
                const data = await response.json();
                
                if (!data.success) {
                    console.error('Failed to load dashboard stats:', data.error);
                    return;
                }
                
                // === LEFT COLUMN: HARDWARE ===
                // System Info
                document.getElementById('home-os').textContent = data.system_info.os || '--';
                document.getElementById('home-kernel').textContent = data.system_info.os_version || '--';
                document.getElementById('home-cpu').textContent = data.system_info.cpu || '--';
                document.getElementById('home-cores').textContent = data.system_info.cpu_cores || '--';
                document.getElementById('home-ram').textContent = `${data.system_info.ram_gb} GB` || '--';
                
                // GPU Info
                if (data.gpu_info) {
                    document.getElementById('home-gpu-model').textContent = data.gpu_info.model || data.gpu_info.type || '--';
                    document.getElementById('home-gpu-vram').textContent = data.gpu_info.vram_gb ? `${data.gpu_info.vram_gb} GB` : 'Nicht erkannt';
                    document.getElementById('home-gpu-gtt').textContent = data.gpu_info.gtt_gb ? `${data.gpu_info.gtt_gb} GB` : '--';
                    document.getElementById('home-gpu-total').textContent = data.gpu_info.total_gb ? `${data.gpu_info.total_gb} GB` : '--';
                } else {
                    document.getElementById('home-gpu-model').textContent = 'Nicht erkannt';
                    document.getElementById('home-gpu-vram').textContent = '--';
                    document.getElementById('home-gpu-gtt').textContent = '--';
                    document.getElementById('home-gpu-total').textContent = '--';
                }
                
                // LM Studio Health
                updateLMStudioHealth(data.lmstudio);
                
                // === BENCHMARK ===
                // Cache Stats
                const totalModels = data.cache_stats.total_models || 0;
                document.getElementById('home-cached-models').textContent = totalModels;

                // Performance Stats
                if (data.perf_stats && data.perf_stats.avg_speed) {
                    const avg = `${data.perf_stats.avg_speed} tok/s`;
                    document.getElementById('home-benchmark-avg-speed').textContent = avg;
                    document.getElementById('home-cache-size').textContent = `${data.cache_stats.db_size_mb} MB`;
                } else {
                    document.getElementById('home-benchmark-avg-speed').textContent = 'Keine Daten';
                    document.getElementById('home-cache-size').textContent = 'Keine Daten';
                }
                
                // Last Run
                if (data.last_run) {
                    const lastRunDate = new Date(data.last_run);
                    const now = new Date();
                    const diffMs = now - lastRunDate;
                    const diffMins = Math.floor(diffMs / 60000);
                    const diffHours = Math.floor(diffMins / 60);
                    const diffDays = Math.floor(diffHours / 24);
                    
                    let timeStr = '';
                    if (diffDays > 0) {
                        timeStr = `vor ${diffDays} Tag${diffDays > 1 ? 'en' : ''}`;
                    } else if (diffHours > 0) {
                        timeStr = `vor ${diffHours}h`;
                    } else if (diffMins > 0) {
                        timeStr = `vor ${diffMins}m`;
                    } else {
                        timeStr = 'gerade eben';
                    }
                    document.getElementById('home-last-run').textContent = timeStr;
                } else {
                    document.getElementById('home-last-run').textContent = 'Nie';
                }
                
                // Fastest Model
                if (data.fastest_model) {
                    document.getElementById('home-fastest-model').textContent = data.fastest_model.name || '--';
                    document.getElementById('home-fastest-speed').textContent = `${data.fastest_model.speed} tok/s` || '--';
                } else {
                    document.getElementById('home-fastest-model').textContent = '--';
                    document.getElementById('home-fastest-speed').textContent = '--';
                }
                
                // Top Models Table
                const topModelsBody = document.getElementById('home-top-models');
                if (data.top_models && data.top_models.length > 0) {
                    topModelsBody.innerHTML = data.top_models.map(model => `
                        <tr style="border-bottom: 1px solid var(--border);">
                            <td style="padding: 0.75rem;">${model.model_name}</td>
                            <td style="padding: 0.75rem;">${model.quantization}</td>
                            <td style="padding: 0.75rem; text-align: right; font-weight: 600; color: var(--success);">${model.speed}</td>
                            <td style="padding: 0.75rem; text-align: right;">${model.vram_mb}</td>
                        </tr>
                    `).join('');
                } else {
                    topModelsBody.innerHTML = '<tr><td colspan="4" style="text-align: center; padding: 2rem; opacity: 0.6;">Keine Daten verfügbar</td></tr>';
                }
                
                // Recent Runs Table
                const recentRunsBody = document.getElementById('home-recent-runs');
                if (data.recent_runs && data.recent_runs.length > 0) {
                    recentRunsBody.innerHTML = data.recent_runs.map(run => `
                        <tr style="border-bottom: 1px solid var(--border);">
                            <td style="padding: 0.75rem;">${run.model_name}</td>
                            <td style="padding: 0.75rem;">${run.quantization}</td>
                            <td style="padding: 0.75rem; text-align: right; font-weight: 600;">${run.speed}</td>
                            <td style="padding: 0.75rem;">${new Date(run.timestamp).toLocaleString('de-DE')}</td>
                        </tr>
                    `).join('');
                } else {
                    recentRunsBody.innerHTML = '<tr><td colspan="4" style="text-align: center; padding: 2rem; opacity: 0.6;">Keine Daten verfügbar</td></tr>';
                }
                
            } catch (error) {
                console.error('Error loading dashboard stats:', error);
                showToast('Fehler beim Laden der Dashboard-Statistiken', 'error');
            }
        }

        // ===== Back to Top Button =====
        function scrollToTop() {
            window.scrollTo({
                top: 0,
                behavior: 'smooth'
            });
        }
        
        window.addEventListener('scroll', () => {
            const backToTopBtn = document.querySelector('.back-to-top');
            if (window.pageYOffset > 300) {
                backToTopBtn.classList.add('show');
            } else {
                backToTopBtn.classList.remove('show');
            }
        });

        // ===== Status Update =====
        async function updateStatus() {
            try {
                const response = await fetch('/api/status');
                const data = await response.json();
                updateStatusBadge(data.status, data.running);
                
                // Update connected clients
                if (data.connected_clients !== undefined) {
                    document.getElementById('clients').textContent = data.connected_clients;
                }
                
                if (data.start_time) {
                    startTime = new Date(data.start_time);
                }
            } catch (error) {
                console.error('Status-Update Fehler:', error);
            }
        }

        function updateStatusBadge(status, running) {
            const badge = document.getElementById('statusBadge');
            const btnStart = document.getElementById('btnStart');
            const btnPause = document.getElementById('btnPause');
            const btnResume = document.getElementById('btnResume');
            const btnStop = document.getElementById('btnStop');

            badge.className = `status-badge status-${status}`;
            
            const icons = {
                idle: '⏸️ Untätig',
                running: '🔄 Läuft',
                paused: '⏸️ Pausiert',
                completed: '✅ Abgeschlossen',
                stopped: '⏹️ Gestoppt'
            };
            
            badge.textContent = icons[status] || status;

            // Button-Status anpassen
            btnStart.disabled = running;
            btnPause.disabled = status !== 'running';
            btnResume.disabled = status !== 'paused';
            btnStop.disabled = !running && status !== 'paused';
        }

        // ===== Uptime Anzeige =====
        function updateUptime() {
            if (!startTime) return;
            
            const elapsed = Math.floor((Date.now() - startTime) / 1000);
            const hours = Math.floor(elapsed / 3600);
            const minutes = Math.floor((elapsed % 3600) / 60);
            const seconds = elapsed % 60;
            
            document.getElementById('uptime').textContent = 
                `${String(hours).padStart(2, '0')}:${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
        }

        // ===== WebSocket Setup =====
        function setupWebSocket() {
            const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
            const wsUrl = `${protocol}//${window.location.host}/ws/benchmark`;
            console.log('🔌 Versuche WebSocket Verbindung zu:', wsUrl);
            
            websocket = new WebSocket(wsUrl);

            websocket.onopen = () => {
                console.log('✅ WebSocket verbunden');
                addAlert('✅ WebSocket verbunden', 'success');
                updateStatus(); // Sofort Status aktualisieren
            };

            websocket.onmessage = (event) => {
                const data = JSON.parse(event.data);
                
                if (data.type === 'output') {
                    appendTerminalLine(data.line);
                    updateStatusBadge(data.status, true);
                } else if (data.type === 'status') {
                    updateStatusBadge(data.status, data.running);
                } else if (data.type === 'completed') {
                    appendTerminalLine(data.message);
                    updateStatusBadge('completed', false);
                    startTime = null;
                    // Stop uptime counter
                    if (uptimeInterval) {
                        clearInterval(uptimeInterval);
                        uptimeInterval = null;
                    }
                    // Aktualisiere Export-Links mit neuen Ergebnissen
                    updateExportLinks();
                    // Lade Results neu
                    setTimeout(() => {
                        loadResults();
                        updateCacheStats();
                    }, 1000);
                } else if (data.type === 'hardware') {
                    updateHardwareCharts(data.data);
                }
            };

            websocket.onerror = (error) => {
                console.error('❌ WebSocket Fehler:', error);
                addAlert('⚠️ WebSocket-Fehler (versuche neu zu verbinden...)', 'warning');
                // Versuche Reconnect nach 3 Sekunden
                setTimeout(() => {
                    console.log('🔄 Versuche WebSocket Reconnect...');
                    setupWebSocket();
                }, 3000);
            };

            websocket.onclose = () => {
                console.log('❌ WebSocket getrennt');
                // Wenn Benchmark noch läuft, versuche automatisch zu reconnecten
                updateStatus().then(() => {
                    if (document.getElementById('statusBadge').classList.contains('status-running')) {
                        console.log('🔄 Benchmark läuft noch - versuche WebSocket Reconnect...');
                        setTimeout(() => setupWebSocket(), 3000);
                    }
                });
            };
        }

        // ===== Terminal Ausgabe =====
        function appendTerminalLine(line) {
            const terminal = document.getElementById('terminal');
            terminal.textContent += line;
            terminal.scrollTop = terminal.scrollHeight;
        }

        function clearTerminal() {
            document.getElementById('terminal').textContent = '';
        }

        // ===== Benchmark Kontrolle =====
        async function startBenchmark() {
            const params = {
                // Basis-Parameter
                runs: parseInt(document.getElementById('paramRuns').value) || null,
                context: parseInt(document.getElementById('paramContext').value) || null,
                limit: parseInt(document.getElementById('paramLimit').value) || null,
                prompt: document.getElementById('paramPrompt').value || null,
                
                // Neue Filter-Parameter
                min_context: parseInt(document.getElementById('paramMinContext').value) || null,
                max_size: parseFloat(document.getElementById('paramMaxSize').value) || null,
                quants: document.getElementById('paramQuants').value || null,
                arch: document.getElementById('paramArch').value || null,
                params: document.getElementById('paramParams').value || null,
                rank_by: document.getElementById('paramRankBy').value || null,
                
                // Regex-Filter
                include_models: document.getElementById('paramInclude').value || null,
                exclude_models: document.getElementById('paramExclude').value || null,
                
                // Boolean Flags
                only_vision: document.getElementById('paramVisionOnly').checked,
                only_tools: document.getElementById('paramToolsOnly').checked,
                retest: document.getElementById('paramRetest').checked,
                dev_mode: document.getElementById('paramDevMode').checked,
                enable_profiling: document.getElementById('paramEnableProfiling').checked,
                disable_gtt: document.getElementById('paramDisableGTT').checked,
                
                // Hardware-Limits
                max_temp: parseFloat(document.getElementById('paramMaxTemp').value) || null,
                max_power: parseFloat(document.getElementById('paramMaxPower').value) || null
            };

            try {
                clearTerminal();
                const response = await fetch('/api/benchmark/start', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(params)
                });
                
                const data = await response.json();
                if (data.success) {
                    showToast('Benchmark wurde gestartet', 'success');
                    toggleStartModal();
                    updateStatus();
                } else {
                    showToast(data.message || 'Fehler beim Starten', 'error');
                }
            } catch (error) {
                showToast(`Fehler: ${error.message}`, 'error');
            }
        }

        async function pauseBenchmark() {
            try {
                const response = await fetch('/api/benchmark/pause', { method: 'POST' });
                const data = await response.json();
                showToast(data.message || 'Pausiert', data.success ? 'success' : 'error');
                updateStatus();
            } catch (error) {
                showToast(`Fehler: ${error.message}`, 'error');
            }
        }

        async function resumeBenchmark() {
            try {
                const response = await fetch('/api/benchmark/resume', { method: 'POST' });
                const data = await response.json();
                showToast(data.message || 'Fortgesetzt', data.success ? 'success' : 'error');
                updateStatus();
            } catch (error) {
                showToast(`Fehler: ${error.message}`, 'error');
            }
        }

        async function stopBenchmark() {
            if (!confirm('Benchmark wirklich beenden?')) return;
            
            try {
                const response = await fetch('/api/benchmark/stop', { method: 'POST' });
                const data = await response.json();
                showToast(data.message || 'Gestoppt', data.success ? 'success' : 'error');
                updateStatus();
                startTime = null;
                // Stop uptime counter
                if (uptimeInterval) {
                    clearInterval(uptimeInterval);
                    uptimeInterval = null;
                }
            } catch (error) {
                showToast(`Fehler: ${error.message}`, 'error');
            }
        }

        // ===== Results Browser =====
        let resultsData = [];
        let sortColumn = 2; // Default: Tokens/s
        let sortAscending = false;

        async function loadResults() {
            try {
                console.log('📥 Lade Results von /api/results...');
                const response = await fetch('/api/results');
                const data = await response.json();
                console.log('📊 API Response:', data);
                resultsData = data.results || [];
                console.log(`✅ ${resultsData.length} Ergebnisse geladen:`, resultsData);
                renderResults();
                updateCacheStats();
                addAlert(`✅ ${resultsData.length} Ergebnisse geladen`, 'success');
            } catch (error) {
                console.error('❌ Fehler beim Laden:', error);
                addAlert(`Fehler beim Laden: ${error.message}`, 'error');
            }
        }

        async function updateCacheStats() {
            try {
                const response = await fetch('/api/cache/stats');
                const data = await response.json();
                if (data.success && data.stats) {
                    const stats = data.stats;
                    const statsText = 
                        `📦 ${stats.total_entries} Einträge | ⚡ Ø ${stats.avg_tokens_per_sec.toFixed(1)} tok/s | ` +
                        `🏆 Schnellste: ${stats.fastest_model} (${stats.fastest_speed.toFixed(1)} tok/s) | ` +
                        `💾 ${stats.db_size_mb.toFixed(2)} MB`;
                    
                    // Update both IDs (für Results-View)
                    const elem = document.getElementById('cache-stats-text-results');
                    if (elem) elem.innerHTML = statsText;
                }
            } catch (error) {
                console.error('Cache-Statistiken laden fehlgeschlagen:', error);
            }
        }

        function renderResults() {
            const tbody = document.getElementById('results-tbody');
            if (!tbody) {
                console.error('results-tbody nicht gefunden');
                return;
            }

            if (!Array.isArray(resultsData) || resultsData.length === 0) {
                tbody.innerHTML = '<tr><td colspan="7" style="text-align: center; padding: 2rem; opacity: 0.6;">Keine Ergebnisse im Cache. Starte einen Benchmark!</td></tr>';
                return;
            }

            // Sortieren mit defensiven Defaults
            const sorted = [...resultsData].sort((a, b) => {
                let aVal, bVal;
                switch(sortColumn) {
                    case 0: aVal = a.model_name || ''; bVal = b.model_name || ''; break;
                    case 1: aVal = a.quantization || ''; bVal = b.quantization || ''; break;
                    case 2: aVal = Number(a.avg_tokens_per_sec) || 0; bVal = Number(b.avg_tokens_per_sec) || 0; break;
                    case 3: aVal = Number(a.vram_mb) || 0; bVal = Number(b.vram_mb) || 0; break;
                    case 4: aVal = Number(a.gpu_offload) || 0; bVal = Number(b.gpu_offload) || 0; break;
                    case 5: aVal = a.gpu_type || ''; bVal = b.gpu_type || ''; break;
                    default: aVal = Number(a.avg_tokens_per_sec) || 0; bVal = Number(b.avg_tokens_per_sec) || 0;
                }
                
                if (typeof aVal === 'string') {
                    return sortAscending ? aVal.localeCompare(bVal) : bVal.localeCompare(aVal);
                }
                return sortAscending ? aVal - bVal : bVal - aVal;
            });

            try {
                const rowsHtml = sorted.map(row => {
                    const tok = Number(row.avg_tokens_per_sec) || 0;
                    const vram = Number(row.vram_mb) || 0;
                    const offload = Number(row.gpu_offload) || 0;
                    const model = row.model_name || 'n/a';
                    const quant = row.quantization || 'n/a';
                    const gpu = row.gpu_type || 'n/a';
                    const key = row.model_key || `${model}@${quant}`;
                    return `
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.08);">
                    <td style="padding: 0.75rem;">${model}</td>
                    <td style="padding: 0.75rem;">${quant}</td>
                    <td style="padding: 0.75rem; text-align: right; font-weight: 600;">${tok.toFixed(2)}</td>
                    <td style="padding: 0.75rem; text-align: right;">${vram.toFixed(0)}</td>
                    <td style="padding: 0.75rem; text-align: right;">${(offload * 100).toFixed(0)}%</td>
                    <td style="padding: 0.75rem;">${gpu}</td>
                    <td style="padding: 0.75rem; text-align: center;">
                        <button onclick="deleteResult('${key}')" class="btn-danger" style="padding: 0.25rem 0.5rem; font-size: 0.8rem;">🗑️</button>
                    </td>
                </tr>`;
                }).join('');
                tbody.innerHTML = rowsHtml;
                console.log('renderResults: rows=', sorted.length, 'html-length=', rowsHtml.length, 'first=', sorted[0]);
                console.log('tbody after render:', tbody.innerHTML.substring(0, 500));
                console.log('tbody children:', tbody.children.length);
                const viewResults = document.getElementById('view-results');
                const section = viewResults.querySelector('.section');
                const card = viewResults.querySelector('.card');
                const table = document.getElementById('results-table');
                console.log('view-results hidden?', viewResults.classList.contains('hidden'));
                console.log('view-results display:', window.getComputedStyle(viewResults).display);
                console.log('view-results height:', viewResults.offsetHeight, 'scrollHeight:', viewResults.scrollHeight);
                console.log('section height:', section?.offsetHeight, 'scrollHeight:', section?.scrollHeight);
                console.log('card height:', card?.offsetHeight, 'scrollHeight:', card?.scrollHeight);
                console.log('table height:', table?.offsetHeight, 'scrollHeight:', table?.scrollHeight);
                console.log('tbody height:', tbody?.offsetHeight, 'scrollHeight:', tbody?.scrollHeight);
                // Force reflow
                viewResults.style.minHeight = 'auto';
                console.log('After reflow - view-results height:', viewResults.offsetHeight);
            } catch (err) {
                console.error('renderResults Fehler:', err, sorted[0]);
                tbody.innerHTML = '<tr><td colspan="7" style="text-align: center; padding: 2rem; opacity: 0.6;">Fehler beim Rendern. Siehe Konsole.</td></tr>';
            }
        }

        function sortTable(column) {
            if (sortColumn === column) {
                sortAscending = !sortAscending;
            } else {
                sortColumn = column;
                sortAscending = false;
            }
            renderResults();
        }

        async function deleteResult(modelKey) {
            if (!confirm(`Cache-Eintrag für "${modelKey}" wirklich löschen?`)) return;
            
            try {
                const response = await fetch(`/api/cache/${encodeURIComponent(modelKey)}`, { method: 'DELETE' });
                const data = await response.json();
                showToast(data.message || 'Eintrag gelöscht', data.success ? 'success' : 'error');
                if (data.success) {
                    await loadResults();
                    await loadDashboardStats();
                }
            } catch (error) {
                showToast(`Fehler: ${error.message}`, 'error');
            }
        }

        async function clearCache() {
            // Doppelte Bestätigung mit Detailinformation
            const confirmClear = confirm(
                '⚠️ WARNUNG: ALLE Benchmark-Ergebnisse werden gelöscht!\n\n' +
                'Diese Aktion:\n' +
                '• Löscht alle gecachten Ergebnisse\n' +
                '• Kann NICHT rückgängig gemacht werden\n' +
                '• Ein automatisches Backup wird erstellt\n\n' +
                'Sicher fortfahren?'
            );
            if (!confirmClear) return;
            
            // Zweite Bestätigung
            const finalConfirm = confirm('✋ LETZTE CHANCE!\n\nBin ich mir wirklich sicher? (Ja = Cache wird gelöscht)');
            if (!finalConfirm) return;
            
            try {
                const response = await fetch('/api/cache/clear', { method: 'POST' });
                const data = await response.json();
                if (data.success) {
                    const backupMsg = data.backup_file ? ` - Backup: ${data.backup_file}` : '';
                    showToast(`Cache gelöscht: ${data.deleted_count} Einträge${backupMsg}`, 'success', 'Cache geleert', 6000);
                    await loadResults();
                    await loadDashboardStats();
                } else {
                    showToast(data.message || 'Fehler beim Löschen', 'error');
                }
            } catch (error) {
                showToast(`Fehler: ${error.message}`, 'error');
            }
        }

        // ===== UI Hilfsfunktionen =====
        function toggleStartModal() {
            document.getElementById('startModal').classList.toggle('hidden');
        }

        function addAlert(message, type = 'info') {
            const alerts = document.getElementById('alerts');
            const alert = document.createElement('div');
            alert.className = `alert alert-${type}`;
            alert.innerHTML = `
                <span>${message}</span>
                <button onclick="this.parentElement.remove()" style="background: none; border: none; color: inherit; cursor: pointer; font-size: 1.5rem; padding: 0;">×</button>
            `;
            alerts.appendChild(alert);
            setTimeout(() => alert.remove(), 5000);
        }

        // ===== Hardware Monitoring Charts =====
        function updateHardwareCharts(hardwareData) {
            if (hardwareData.temperatures && hardwareData.temperatures.length > 0) {
                updateTemperatureChart(hardwareData.temperatures);
            }
            if (hardwareData.power && hardwareData.power.length > 0) {
                updatePowerChart(hardwareData.power);
            }
            if (hardwareData.vram && hardwareData.vram.length > 0) {
                updateVramChart(hardwareData.vram);
            }
            if (hardwareData.gtt && hardwareData.gtt.length > 0) {
                updateGttChart(hardwareData.gtt);
            }
            if (hardwareData.cpu && hardwareData.cpu.length > 0) {
                updateCpuChart(hardwareData.cpu);
            }
            if (hardwareData.ram && hardwareData.ram.length > 0) {
                updateRamChart(hardwareData.ram);
            }
        }

        function updateTemperatureChart(data) {
            const timestamps = data.map(d => new Date(d.timestamp).toLocaleTimeString('de-DE'));
            const values = data.map(d => d.value);
            
            const trace = {
                x: timestamps,
                y: values,
                type: 'scatter',
                mode: 'lines+markers',
                name: 'Temperature (°C)',
                line: {color: '#ef4444', width: 2},
                marker: {size: 4},
                fill: 'tozeroy',
                fillcolor: 'rgba(239, 68, 68, 0.1)'
            };
            
            const layout = {
                title: false,
                hovermode: 'x unified',
                margin: {l: 50, r: 20, t: 20, b: 40},
                plot_bgcolor: 'rgba(0,0,0,0.02)',
                paper_bgcolor: 'rgba(0,0,0,0)',
                font: {color: document.body.classList.contains('dark-mode') ? '#f3f4f6' : '#1f2937'},
                xaxis: {showgrid: false, showticklabels: false},
                yaxis: {showgrid: false}
            };
            
            Plotly.newPlot('chart-temperature', [trace], layout, {responsive: true, displayModeBar: false});
            
            // Update Stats
            const min = Math.min(...values);
            const max = Math.max(...values);
            const avg = (values.reduce((a,b) => a+b, 0) / values.length).toFixed(1);
            document.getElementById('temp-min').textContent = `${min.toFixed(1)}°C`;
            document.getElementById('temp-max').textContent = `${max.toFixed(1)}°C`;
            document.getElementById('temp-avg').textContent = `${avg}°C`;
        }

