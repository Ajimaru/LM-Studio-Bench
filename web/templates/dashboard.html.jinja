                <option value="theme-cyberpunk">💠 Cyberpunk</option>
                <option value="theme-pastel">🧁 Pastel</option>
                <option value="theme-sepia">📜 Sepia</option>
                <option value="theme-80s">🎹 80er Retro</option>
