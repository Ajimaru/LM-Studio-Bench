    </header>

    <div class="container">
        <!-- HOME VIEW -->
        <div id="view-home" class="view-container">
            <!-- Welcome Banner -->
            <div class="card" style="background: linear-gradient(135deg, var(--primary) 0%, #1e40af 100%); color: white; margin-bottom: 2rem;">
                <h2 style="color: white;">🚀 Willkommen zum LM Studio Benchmark Dashboard</h2>
                <p style="opacity: 0.9; margin: 0.5rem 0;">Teste und vergleiche deine LLM-Modelle mit präzisen Performance-Metriken</p>
            </div>

            <!-- Cache & Performance Stats -->
            <div class="grid" style="grid-template-columns: 1fr; gap: 2rem;">
                <!-- RIGHT COLUMN: HARDWARE & BENCHMARK -->
                <div class="card">
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; font-size: 0.9rem;">
                        <!-- LEFT COLUMN: HARDWARE -->
                        <div>
                            <div style="color: var(--primary); font-weight: 600; margin-bottom: 0.75rem; padding-bottom: 0.5rem; border-bottom: 2px solid var(--primary);">🖥️ HARDWARE</div>
