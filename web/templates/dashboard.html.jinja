                                <div><span style="color: var(--text); font-weight: 500;">OS:</span> <span id="home-os">--</span></div>
                                <div><span style="color: var(--text); font-weight: 500;">Kernel:</span> <span id="home-kernel">--</span></div>
                                <div><span style="color: var(--text); font-weight: 500;">CPU:</span> <span id="home-cpu">--</span></div>
                                <div><span style="color: var(--text); font-weight: 500;">Kerne:</span> <span id="home-cores">--</span></div>
                                <div><span style="color: var(--text); font-weight: 500;">RAM:</span> <span id="home-ram">--</span></div>
                            </div>
                            <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid rgba(0,0,0,0.1); color: var(--text-light); line-height: 1.8;">
                                <div><span style="color: var(--text); font-weight: 500;">GPU Modell:</span> <span id="home-gpu-model">--</span></div>
                                <div><span style="color: var(--text); font-weight: 500;">GPU VRAM:</span> <span id="home-gpu-vram">--</span></div>
                                <div><span style="color: var(--text); font-weight: 500;">System RAM (GTT):</span> <span id="home-gpu-gtt">--</span></div>
                                <div><span style="color: var(--text); font-weight: 500;">Verfügbar:</span> <span id="home-gpu-total">--</span></div>
                            </div>
                            <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid rgba(0,0,0,0.1); color: var(--text-light); line-height: 1.8;">
                                <div><span style="color: var(--text); font-weight: 500;">LM Studio:</span> <span id="home-lmstudio-version">--</span></div>
                            </div>
                        </div>

                        <!-- RIGHT COLUMN: BENCHMARK (mit zusätzlichen Details) -->
                        <div>
                            <div style="color: #e74c3c; font-weight: 600; margin-bottom: 0.75rem; padding-bottom: 0.5rem; border-bottom: 2px solid #e74c3c;">📊 BENCHMARK</div>
                            <div style="color: var(--text-light); line-height: 1.8;">
                                <div><span style="color: var(--text); font-weight: 500;">Gecachte Modelle:</span> <span id="home-cached-models">--</span></div>
                                <div><span style="color: var(--text); font-weight: 500;">Ø Geschwindigkeit:</span> <span id="home-benchmark-avg-speed">--</span></div>
                                <div><span style="color: var(--text); font-weight: 500;">Cache Größe:</span> <span id="home-cache-size">--</span></div>
                                <div><span style="color: var(--text); font-weight: 500;">Letzter Durchlauf:</span> <span id="home-last-run">--</span></div>
                            </div>
                            <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid rgba(0,0,0,0.1); color: var(--text-light); line-height: 1.8;">
                                <div><span style="color: var(--text); font-weight: 500;">🏆 Schnellstes Modell:</span></div>
                                <div style="margin-left: 1rem; margin-top: 0.5rem;">
                                    <div><span style="color: var(--text); font-weight: 500;">Name:</span> <span id="home-fastest-model">--</span></div>
                                    <div><span style="color: var(--text); font-weight: 500;">Geschwindigkeit:</span> <span id="home-fastest-speed">--</span></div>
                                </div>
                            </div>
                            <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid rgba(0,0,0,0.1); display: flex; flex-direction: column; gap: 0.75rem;">
                                <button onclick="showView('benchmark')" style="padding: 0.5rem; background: var(--primary); color: white; border: none; border-radius: 0.5rem; cursor: pointer; font-weight: 500; transition: opacity 0.2s;">⚡ Benchmark starten</button>
                                <button onclick="showView('results')" style="padding: 0.5rem; background: var(--success); color: white; border: none; border-radius: 0.5rem; cursor: pointer; font-weight: 500; transition: opacity 0.2s;">📊 Ergebnisse</button>
                            </div>
                        </div>
                    </div>
                </div>
