                <div class="checkbox-group" style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
                    <div class="checkbox-item">
                        <input type="checkbox" id="paramVisionOnly">
                        <label for="paramVisionOnly">Nur Vision-Modelle</label>
                    </div>
                    <div class="checkbox-item">
                        <input type="checkbox" id="paramToolsOnly">
                        <label for="paramToolsOnly">Nur Tool-Modelle</label>
                    </div>
                    <div class="checkbox-item">
                        <input type="checkbox" id="paramRetest">
                        <label for="paramRetest">Bereits getestete Modelle neu testen</label>
                    </div>
                    <div class="checkbox-item">
                        <input type="checkbox" id="paramDevMode">
                        <label for="paramDevMode">Dev-Mode (1 Modell, 1 Run)</label>
                    </div>
                    <div class="checkbox-item">
                        <input type="checkbox" id="paramEnableProfiling" checked>
                        <label for="paramEnableProfiling">Hardware-Profiling (GPU Temp/Power)</label>
                    </div>
                    <div class="checkbox-item">
                        <input type="checkbox" id="paramDisableGTT">
                        <label for="paramDisableGTT">GTT deaktivieren (nur VRAM)</label>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1rem;">
                    <div class="form-group">
                        <label>Max. GPU-Temperatur (°C)</label>
                        <input type="number" id="paramMaxTemp" placeholder="z.B. 85.0" min="30" max="120" step="0.1">
                    </div>
                    <div class="form-group">
                        <label>Max. GPU Power (Watts)</label>
                        <input type="number" id="paramMaxPower" placeholder="z.B. 400.0" min="50" max="1000" step="0.1">
                    </div>
                </div>
            </div>

            <div class="controls" style="gap: 1rem; margin-top: 1rem;">
                <button class="btn-success" onclick="startBenchmark()">✅ Benchmark Starten</button>
                <button class="btn-primary" onclick="toggleStartModal()">❌ Abbrechen</button>
            </div>
        </div>

        <!-- Hardware Monitoring Charts -->
        <div class="section">
            <h3>💻 Hardware-Monitoring (Live)</h3>
            <div class="hardware-charts-container">
                <div class="chart-card">
                    <h4>🌡️ GPU-Temperatur</h4>
                    <div id="chart-temperature" style="height: 300px;"></div>
                    <div class="chart-stats">
                        <div class="chart-stat">
                            <div class="chart-stat-label">Min</div>
                            <div class="chart-stat-value" id="temp-min">--°C</div>
                        </div>
                        <div class="chart-stat">
                            <div class="chart-stat-label">Ø</div>
                            <div class="chart-stat-value" id="temp-avg">--°C</div>
                        </div>
                        <div class="chart-stat">
                            <div class="chart-stat-label">Max</div>
                            <div class="chart-stat-value" id="temp-max">--°C</div>
                        </div>
                    </div>
                </div>

                <div class="chart-card">
                    <h4>⚡ GPU-Leistung</h4>
                    <div id="chart-power" style="height: 300px;"></div>
                    <div class="chart-stats">
                        <div class="chart-stat">
                            <div class="chart-stat-label">Min</div>
                            <div class="chart-stat-value" id="power-min">--W</div>
                        </div>
                        <div class="chart-stat">
                            <div class="chart-stat-label">Ø</div>
                            <div class="chart-stat-value" id="power-avg">--W</div>
                        </div>
                        <div class="chart-stat">
                            <div class="chart-stat-label">Max</div>
                            <div class="chart-stat-value" id="power-max">--W</div>
                        </div>
                    </div>
                </div>

                <div class="chart-card">
