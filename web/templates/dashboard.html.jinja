                <option value="theme-solarized-light">🌅 Solarized Light</option>
                <option value="theme-gruvbox">🧱 Gruvbox</option>
                <option value="theme-dracula">🦇 Dracula</option>
                <option value="theme-nord">❄️ Nord</option>
                <option value="theme-monokai">🌈 Monokai Pro</option>
                <option value="theme-paper">📄 Paper</option>
                <option value="theme-terminal-green">🖥️ Terminal Green</option>
                <option value="theme-oled">🖤 OLED Black</option>
