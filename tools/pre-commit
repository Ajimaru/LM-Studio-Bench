#!/usr/bin/env bash
#
# Pre-commit hook for LM-Studio-Bench
# Runs code quality checks on staged files:
# - Python: flake8, isort, pylint (optional)
# - Shell: shellcheck
# - Markdown: markdownlint
# - HTML/Jinja: djlint
#
# Installation: Run tools/install-hooks.sh
# Skip pylint: SKIP_PYLINT=1 git commit
#

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}Running pre-commit checks...${NC}"

# Get the project root directory
PROJECT_ROOT=$(git rev-parse --show-toplevel)
cd "$PROJECT_ROOT"

# Set up logging
LOGS_DIR="$PROJECT_ROOT/logs"
mkdir -p "$LOGS_DIR"
TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
LOG_FILE="$LOGS_DIR/pre_commit_${TIMESTAMP}.log"
LATEST_LINK="$LOGS_DIR/pre_commit_latest.log"
: > "$LOG_FILE"
rm -f "$LATEST_LINK"
ln -s "$(basename "$LOG_FILE")" "$LATEST_LINK"
exec > >(
    tee >(
        sed -E 's/\x1B\[[0-9;]*[[:alpha:]]//g' >> "$LOG_FILE"
    )
) 2>&1
echo -e "${YELLOW}Logging to ${LOG_FILE}${NC}"

# Check if virtual environment is activated
if [[ -z "${VIRTUAL_ENV}" ]]; then
    if [[ -f ".venv/bin/activate" ]]; then
        echo -e "${YELLOW}Activating virtual environment...${NC}"
        # shellcheck disable=SC1091
        source .venv/bin/activate
    fi
fi

# Get list of staged files by type
readarray -t STAGED_FILES < <(git diff --cached --name-only --diff-filter=ACM)
readarray -t PYTHON_FILES < <(
    printf '%s\n' "${STAGED_FILES[@]}" | grep -E '\.py$' || true
)
readarray -t BASH_FILES < <(
    printf '%s\n' "${STAGED_FILES[@]}" | grep -E '\.(sh|bash)$' || true
)
readarray -t MARKDOWN_FILES < <(
    printf '%s\n' "${STAGED_FILES[@]}" | grep -E '\.md$' || true
)
readarray -t HTML_JINJA_FILES < <(
    printf '%s\n' "${STAGED_FILES[@]}" | grep -E '\.(html|jinja|jinja2)$' || true
)

# Check if there are any files to check
if [[ ${#PYTHON_FILES[@]} -eq 0 && ${#BASH_FILES[@]} -eq 0 && \
      ${#MARKDOWN_FILES[@]} -eq 0 && ${#HTML_JINJA_FILES[@]} -eq 0 ]]; then
    echo -e "${GREEN}No files to check.${NC}"
    exit 0
fi

# Flag to track if any checks fail
FAILED=0

# Track files that were automatically fixed
AUTOFIXED_FILES=()

add_autofixed_file() {
    local file="$1"
    local existing_file

    for existing_file in "${AUTOFIXED_FILES[@]}"; do
        if [[ "$existing_file" == "$file" ]]; then
            return
        fi
    done

    AUTOFIXED_FILES+=("$file")
}

restage_autofixed_files() {
    if [[ ${#AUTOFIXED_FILES[@]} -eq 0 ]]; then
        return
    fi

    echo ""
    echo -e "${YELLOW}Re-staging auto-fixed files...${NC}"
    git add -- "${AUTOFIXED_FILES[@]}"
    echo -e "${GREEN}✓ Auto-fixed files re-staged${NC}"
}

# ============================================================================
# Python Checks
# ============================================================================
if [[ ${#PYTHON_FILES[@]} -gt 0 ]]; then
    echo ""
    echo -e "${YELLOW}═══ Python Checks ═══${NC}"

    # Run isort (auto-fix if needed)
    echo -e "${YELLOW}Running isort...${NC}"
    if ! isort --check-only --diff "${PYTHON_FILES[@]}"; then
        echo -e "${YELLOW}Applying isort auto-fix...${NC}"
        if isort "${PYTHON_FILES[@]}"; then
            for file in "${PYTHON_FILES[@]}"; do
                add_autofixed_file "$file"
            done
            echo -e "${GREEN}✓ isort auto-fix applied${NC}"
        else
            echo -e "${RED}❌ isort auto-fix failed!${NC}"
            FAILED=1
        fi
    else
        echo -e "${GREEN}✓ isort passed${NC}"
    fi

    # Run flake8
    echo -e "${YELLOW}Running flake8...${NC}"
    if ! flake8 "${PYTHON_FILES[@]}"; then
        echo -e "${YELLOW}⚠ flake8 found issues (non-blocking)${NC}"
    else
        echo -e "${GREEN}✓ flake8 passed${NC}"
    fi

    # Run pylint (optional, with timeout)
    if [[ -z "$SKIP_PYLINT" ]]; then
        echo -e "${YELLOW}Running pylint (timeout 15s)...${NC}"
        readarray -t PYLINT_FILES < <(
            printf '%s\n' "${PYTHON_FILES[@]}" | \
                grep -E '^(src|web)/' || true
        )

        if [[ ${#PYLINT_FILES[@]} -gt 0 ]]; then
            if timeout 15s pylint "${PYLINT_FILES[@]}" --exit-zero; then
                echo -e "${GREEN}✓ pylint passed${NC}"
            else
                EXIT_CODE=$?
                if [[ $EXIT_CODE -eq 124 ]]; then
                    echo -e "${YELLOW}⚠ pylint timeout (non-blocking)${NC}"
                else
                    echo -e "${YELLOW}⚠ pylint found issues (non-blocking)${NC}"
                fi
            fi
        fi
    fi
fi

# ============================================================================
# Bash/Shell Checks
# ============================================================================
if [[ ${#BASH_FILES[@]} -gt 0 ]]; then
    echo ""
    echo -e "${YELLOW}═══ Shell Script Checks ═══${NC}"

    # Run shellcheck
    echo -e "${YELLOW}Running shellcheck...${NC}"
    if ! shellcheck "${BASH_FILES[@]}"; then
        echo -e "${RED}❌ shellcheck found issues!${NC}"
        FAILED=1
    else
        echo -e "${GREEN}✓ shellcheck passed${NC}"
    fi
fi

# ============================================================================
# Markdown Checks
# ============================================================================
if [[ ${#MARKDOWN_FILES[@]} -gt 0 ]]; then
    echo ""
    echo -e "${YELLOW}═══ Markdown Checks ═══${NC}"

    # Run markdownlint
    echo -e "${YELLOW}Running markdownlint...${NC}"
    if ! markdownlint -c "$PROJECT_ROOT/.markdownlintrc.json" \
        "${MARKDOWN_FILES[@]}"; then
        echo -e "${RED}❌ markdownlint found issues!${NC}"
        FAILED=1
    else
        echo -e "${GREEN}✓ markdownlint passed${NC}"
    fi
fi

# ============================================================================
# HTML/Jinja Checks
# ============================================================================
if [[ ${#HTML_JINJA_FILES[@]} -gt 0 ]]; then
    echo ""
    echo -e "${YELLOW}═══ HTML/Jinja Checks ═══${NC}"

    # Run djlint (auto-fix if needed)
    echo -e "${YELLOW}Running djlint...${NC}"
    if ! djlint --check "${HTML_JINJA_FILES[@]}"; then
        echo -e "${YELLOW}Applying djlint auto-fix...${NC}"
        if djlint --reformat "${HTML_JINJA_FILES[@]}"; then
            for file in "${HTML_JINJA_FILES[@]}"; do
                add_autofixed_file "$file"
            done
            echo -e "${GREEN}✓ djlint auto-fix applied${NC}"
        else
            echo -e "${RED}❌ djlint auto-fix failed!${NC}"
            FAILED=1
        fi
    else
        echo -e "${GREEN}✓ djlint passed${NC}"
    fi
fi

# ============================================================================
# Final Result
# ============================================================================
restage_autofixed_files

echo ""
if [[ $FAILED -ne 0 ]]; then
    echo -e "${RED}Pre-commit checks failed!${NC}"
    echo -e "${YELLOW}Please fix the issues above and try again.${NC}"
    echo ""
    echo -e "To skip these checks, use: ${YELLOW}git commit --no-verify${NC}"
    echo -e "To skip pylint, use: ${YELLOW}SKIP_PYLINT=1 git commit${NC}"
    echo ""
    exit 1
fi

echo -e "${GREEN}All pre-commit checks passed! ✓${NC}"
exit 0

