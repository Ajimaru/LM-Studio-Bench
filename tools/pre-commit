#!/usr/bin/env bash
#
# Pre-commit hook for LM-Studio-Bench
# Runs code quality checks on staged files:
# - Python: flake8, isort, pylint (optional)
# - Shell: shellcheck
# - Markdown: markdownlint
# - HTML/Jinja: djlint
#
# Installation: Run tools/install-hooks.sh
# Skip pylint: SKIP_PYLINT=1 git commit
#

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}Running pre-commit checks...${NC}"

# Get the project root directory
PROJECT_ROOT=$(git rev-parse --show-toplevel)
cd "$PROJECT_ROOT"

# Check if virtual environment is activated
if [[ -z "${VIRTUAL_ENV}" ]]; then
    if [[ -f ".venv/bin/activate" ]]; then
        echo -e "${YELLOW}Activating virtual environment...${NC}"
        source .venv/bin/activate
    fi
fi

# Get list of staged files by type
PYTHON_FILES=$(git diff --cached --name-only --diff-filter=ACM | \
    grep -E '\.py$' || true)
BASH_FILES=$(git diff --cached --name-only --diff-filter=ACM | \
    grep -E '\.(sh|bash)$' || true)
MARKDOWN_FILES=$(git diff --cached --name-only --diff-filter=ACM | \
    grep -E '\.md$' || true)
HTML_JINJA_FILES=$(git diff --cached --name-only --diff-filter=ACM | \
    grep -E '\.(html|jinja|jinja2)$' || true)

# Check if there are any files to check
if [[ -z "$PYTHON_FILES" && -z "$BASH_FILES" && \
      -z "$MARKDOWN_FILES" && -z "$HTML_JINJA_FILES" ]]; then
    echo -e "${GREEN}No files to check.${NC}"
    exit 0
fi

# Flag to track if any checks fail
FAILED=0

# ============================================================================
# Python Checks
# ============================================================================
if [[ -n "$PYTHON_FILES" ]]; then
    echo ""
    echo -e "${YELLOW}═══ Python Checks ═══${NC}"

    # Run isort
    echo -e "${YELLOW}Running isort...${NC}"
    if ! isort --check-only --diff $PYTHON_FILES; then
        echo -e "${RED}❌ isort found issues!${NC}"
        echo -e "${YELLOW}Fix with: isort $PYTHON_FILES${NC}"
        FAILED=1
    else
        echo -e "${GREEN}✓ isort passed${NC}"
    fi

    # Run flake8
    echo -e "${YELLOW}Running flake8...${NC}"
    if ! flake8 $PYTHON_FILES; then
        echo -e "${RED}❌ flake8 found issues!${NC}"
        FAILED=1
    else
        echo -e "${GREEN}✓ flake8 passed${NC}"
    fi

    # Run pylint (optional, with timeout)
    if [[ -z "$SKIP_PYLINT" ]]; then
        echo -e "${YELLOW}Running pylint (timeout 10s)...${NC}"
        PYLINT_FILES=$(echo "$PYTHON_FILES" | \
            grep -E '^(src|web)/' || true)

        if [[ -n "$PYLINT_FILES" ]]; then
            if timeout 10s pylint $PYLINT_FILES --exit-zero; then
                echo -e "${GREEN}✓ pylint passed${NC}"
            else
                EXIT_CODE=$?
                if [[ $EXIT_CODE -eq 124 ]]; then
                    echo -e "${YELLOW}⚠ pylint timeout (skipping)${NC}"
                else
                    echo -e "${RED}❌ pylint found issues!${NC}"
                    FAILED=1
                fi
            fi
        fi
    fi
fi

# ============================================================================
# Bash/Shell Checks
# ============================================================================
if [[ -n "$BASH_FILES" ]]; then
    echo ""
    echo -e "${YELLOW}═══ Shell Script Checks ═══${NC}"

    # Run shellcheck
    echo -e "${YELLOW}Running shellcheck...${NC}"
    if ! shellcheck $BASH_FILES; then
        echo -e "${RED}❌ shellcheck found issues!${NC}"
        FAILED=1
    else
        echo -e "${GREEN}✓ shellcheck passed${NC}"
    fi
fi

# ============================================================================
# Markdown Checks
# ============================================================================
if [[ -n "$MARKDOWN_FILES" ]]; then
    echo ""
    echo -e "${YELLOW}═══ Markdown Checks ═══${NC}"

    # Run markdownlint
    echo -e "${YELLOW}Running markdownlint...${NC}"
    if ! markdownlint $MARKDOWN_FILES; then
        echo -e "${RED}❌ markdownlint found issues!${NC}"
        FAILED=1
    else
        echo -e "${GREEN}✓ markdownlint passed${NC}"
    fi
fi

# ============================================================================
# HTML/Jinja Checks
# ============================================================================
if [[ -n "$HTML_JINJA_FILES" ]]; then
    echo ""
    echo -e "${YELLOW}═══ HTML/Jinja Checks ═══${NC}"

    # Run djlint
    echo -e "${YELLOW}Running djlint...${NC}"
    if ! djlint --check $HTML_JINJA_FILES; then
        echo -e "${RED}❌ djlint found issues!${NC}"
        echo -e "${YELLOW}Fix with: djlint --reformat $HTML_JINJA_FILES${NC}"
        FAILED=1
    else
        echo -e "${GREEN}✓ djlint passed${NC}"
    fi
fi

# ============================================================================
# Final Result
# ============================================================================
echo ""
if [[ $FAILED -ne 0 ]]; then
    echo -e "${RED}Pre-commit checks failed!${NC}"
    echo -e "${YELLOW}Please fix the issues above and try again.${NC}"
    echo ""
    echo -e "To skip these checks, use: ${YELLOW}git commit --no-verify${NC}"
    echo -e "To skip pylint, use: ${YELLOW}SKIP_PYLINT=1 git commit${NC}"
    echo ""
    exit 1
fi

echo -e "${GREEN}All pre-commit checks passed! ✓${NC}"
exit 0

