# Flake8 Configuration for LM-Studio-Bench
# See: https://flake8.pycqa.org/en/latest/user/configuration.html

[flake8]
# Maximum line length (Black standard: 88)
max-line-length = 88

# Exclude directories
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    env,
    build,
    dist,
    *.egg-info,
    .tox,
    .pytest_cache,
    .mypy_cache,
    node_modules,
    book

# Ignore specific errors
ignore =
    # E203: whitespace before ':' (conflicts with black)
    E203,
    # W503: line break before binary operator (conflicts with black)
    W503,
    # E501: line too long (handled by max-line-length)
    E501,
    # C901: function is too complex
    C901

# Enable additional checks
select =
    # pycodestyle errors
    E,
    # pycodestyle warnings
    W,
    # pyflakes
    F,
    # mccabe complexity
    C,
    # pep8-naming
    N

# McCabe complexity (max 12 - keep code maintainable)
max-complexity = 12

# Show source code for errors
show-source = True

# Show pep8 violation for each error
show-pep8 = True

# Count errors
count = True

# Statistics
statistics = True
